#!/usr/bin/env bash
# Pre-commit gate: the tree must be green before a commit lands.
# Bypass in genuine emergencies with `git commit --no-verify`.
set -euo pipefail

echo "pre-commit: cargo fmt --check ..."
cargo fmt --all --check

echo "pre-commit: cargo clippy -D warnings ..."
cargo clippy --workspace --all-targets -- -D warnings

echo "pre-commit: cargo llvm-cov (tests + >=90% line coverage) ..."
cargo llvm-cov --workspace --fail-under-lines 90

echo "pre-commit: ok"
